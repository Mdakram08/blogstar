          <a class="nav-link active fw-semibold" href="/admin" style="color:#1a1a2e !important;">
            <i class="fa-solid fa-shield-halved"></i> Admin
          </a>
        </li>
        <% } %>
      </ul>
      
      <div class="curruser">
