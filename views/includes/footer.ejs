<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Wunderlust Footer</title>
  
  <style>
    .footer {
     background-color: whitesmoke;
     color: black;    
     padding: 20px 0;
    }
    .footer .social-icons a {
      color: rgb(0, 0, 0);
      font-size: 20px;
      margin: 0 10px;
      transition: color 0.3s;
    }
    .footer .social-icons a:hover {
      color: #0d6efd;
    }
  </style>
</head>
<body>
