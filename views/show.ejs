<% layout("/layouts/boilerplate") %>
<!-- //new code tough -->
<body>
  <br>

  <div class="carsd">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10">

        <!-- Blog Show -->
        <div class="card-image">

          <h1><%= Blog.title %></h1>

          <h5 class="authorname">
            <b style="color: rgb(5, 5, 72);">Author:</b>
            <a href="/<%= Blog.owner._id %>/profile">
              <%= Blog.owner.username %>
            </a>
          </h5>

          <br>

          <img
            src="<%= Blog.image.url %>"
            class="card-img-top imageshow img-fluid"
            alt="<%= Blog.title %>"
          >

          <br><br>

          <div class="card-content">
            <p><b>Title:</b> <%= Blog.title %></p>
            <p><b>Description:</b> <%= Blog.description %></p>
            <p><b>Content:</b> <%= Blog.content %></p>
          </div>

          <!-- Edit/Delete buttons -->
          <% if(currUser && currUser._id.equals(Blog.owner._id)){ %>
            <div class="btns mt-3 d-flex gap-2">
              <a href="/blog/<%= Blog.id %>/edit">
                <button class="btn btn-dark">Edit</button>
              </a>

              <form action="/blog/<%= Blog.id %>?_method=DELETE" method="POST">
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
          <% } %>

          <!-- Review Form -->
          <% if(currUser){ %>

            <br>
            <div class="review-form">
              <hr>

              <h1>
                Comment your Thoughts!
                <br>
                <h6 style="color: rgb(5, 5, 72);">
                  "<%= Blog.title %>"
                </h6>
              </h1>

              <form
                action="/blog/<%= Blog.id %>/reviews"
                method="POST"
                class="needs-validation"
                novalidate
              >

                <div class="star">
                  <label for="rating" class="form-label">
                    <b>Rating:</b>
                  </label>

                  <fieldset class="starability-basic">

                    <input
                      type="radio"
                      id="no-rate"
                      class="input-no-rate"
                      name="review[rating]"
                      value="1"
                      checked
                      aria-label="No rating."
                    >

                    <input type="radio" id="first-rate1" name="review[rating]" value="1">
                    <label for="first-rate1" title="Terrible">1 star</label>

                    <input type="radio" id="first-rate2" name="review[rating]" value="2">
                    <label for="first-rate2" title="Not good">2 stars</label>

                    <input type="radio" id="first-rate3" name="review[rating]" value="3">
                    <label for="first-rate3" title="Average">3 stars</label>

                    <input type="radio" id="first-rate4" name="review[rating]" value="4">
                    <label for="first-rate4" title="Very good">4 stars</label>

                    <input type="radio" id="first-rate5" name="review[rating]" value="5">
                    <label for="first-rate5" title="Amazing">5 stars</label>

                  </fieldset>
                </div>

                <div class="mb-3">
                  <label for="comment" class="form-label">
                    <b>Comment:</b>
                  </label>

                  <textarea
                    name="review[comment]"
                    class="form-control"
                    rows="10"
                    required
                  ></textarea>

                  <div class="invalid-feedback">
                    Please provide a valuable comment.
                  </div>

                  <div class="valid-feedback">
                    Nice!
                  </div>
                </div>

                <button class="btn btn-dark mt-3">
                  Submit
                </button>

              </form>
            </div>

          <% } %>

          <!-- Reviews Section -->
          <hr>

          <div class="review-show">

            <% if(Blog.reviews.length > 0){ %>
              <h2><b>Comments</b></h2>
            <% } %>

            <% for(const review of Blog.reviews){ %>

              <div class="row mt-2">
                <div class="card mb-2 cd">

                  <div class="comment-div p-3">

                    <div class="div-img mb-2">
                      <b
                        style="color: rgb(66, 66, 168);"
                        class="authorname"
                      >
                        <a href="/<%= review.author._id %>/profile">
                          @<%= review.author.username %>
                        </a>
                      </b>
                    </div>

                    <div class="review-text">

                      <p
                        class="starability-result card-text-rating"
                        data-rating="<%= review.rating %>"
                      ></p>

                      <b>Comment:</b>
                      <span class="review-comment">
                        <%= review.comment %>
                      </span>

                    </div>

                    <% if(currUser && currUser._id.equals(review.author._id)){ %>

                      <form
                        action="/blog/<%= Blog.id %>/reviews/<%= review.id %>?_method=DELETE"
                        method="POST"
                        class="mt-2"
                      >
                        <button class="btn btn-danger btn-sm">
                          Delete
                        </button>
                      </form>

                    <% } %>

                  </div>
                </div>
              </div>

            <% } %>

          </div>

        </div>
      </div>
    </div>
  </div>

</body>

<!-- Bootstrap Form Validation -->
<script>
(() => {
  'use strict';

  const forms = document.querySelectorAll('.needs-validation');

  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }

      form.classList.add('was-validated');
    }, false);
  });
})();
</script>