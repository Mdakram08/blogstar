<% layout('layouts/boilerplate') %>

<style>
  .admin-header {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    border: none;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    transition: transform 0.2s;
  }
  .stat-card:hover { transform: translateY(-3px); }
  .stat-icon { font-size: 2rem; opacity: 0.8; }
  .section-title {
    font-weight: 700;
    color: #1a1a2e;
    border-left: 4px solid #1a1a2e;
    padding-left: 0.75rem;
    margin: 2rem 0 1rem;
  }
  .admin-table th { background-color: #f8f9fa; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .badge-admin { background-color: #1a1a2e; }
</style>

<div class="admin-header d-flex justify-content-between align-items-center mt-3">
  <div>
    <h2 class="mb-1"><i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard</h2>
    <p class="mb-0 opacity-75">Welcome back, <strong><%= currUser.username %></strong></p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/users" class="btn btn-light btn-sm"><i class="fa-solid fa-users me-1"></i>Manage Users</a>
    <a href="/admin/blogs" class="btn btn-outline-light btn-sm"><i class="fa-solid fa-newspaper me-1"></i>Manage Blogs</a>
  </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-2">
  <div class="col-md-4">
    <div class="card stat-card p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <p class="text-muted mb-1 small">Total Blogs</p>
          <h3 class="mb-0 fw-bold"><%= totalBlogs %></h3>
        </div>
        <div class="stat-icon text-primary"><i class="fa-solid fa-newspaper"></i></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <p class="text-muted mb-1 small">Total Users</p>
          <h3 class="mb-0 fw-bold"><%= totalUsers %></h3>
        </div>
        <div class="stat-icon text-success"><i class="fa-solid fa-users"></i></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <p class="text-muted mb-1 small">Total Reviews</p>
          <h3 class="mb-0 fw-bold"><%= totalReviews %></h3>
        </div>
        <div class="stat-icon text-warning"><i class="fa-solid fa-star"></i></div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Blogs -->
<h5 class="section-title">Recent Blogs</h5>
<div class="card border-0 shadow-sm mb-4">
  <div class="table-responsive">
    <table class="table admin-table mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Author</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% for(let b of recentBlogs){ %>
        <tr>
          <td><a href="/blog/<%= b._id %>" class="text-decoration-none text-dark fw-semibold"><%= b.title %></a></td>
          <td><span class="badge bg-secondary"><%= b.category %></span></td>
          <td><%= b.owner ? b.owner.username : "Deleted User" %></td>
          <td>
            <form action="/admin/blogs/<%= b._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this blog?')">
              <button class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash"></i></button>
            </form>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Recent Users -->
<h5 class="section-title">Recent Users</h5>
<div class="card border-0 shadow-sm mb-4">
  <div class="table-responsive">
    <table class="table admin-table mb-0">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
        </tr>
      </thead>
      <tbody>
        <% for(let u of recentUsers){ %>
        <tr>
          <td class="fw-semibold"><%= u.username %></td>
          <td class="text-muted"><%= u.email %></td>
          <td>
            <% if(u.isAdmin){ %>
              <span class="badge badge-admin">Admin</span>
            <% } else { %>
              <span class="badge bg-light text-dark border">User</span>
            <% } %>
          </td>
          <td class="text-muted small"><%= new Date(u.createdAt).toLocaleDateString() %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="text-end mb-4">
  <a href="/admin/users" class="btn btn-dark btn-sm me-2">View All Users →</a>
  <a href="/admin/blogs" class="btn btn-dark btn-sm">View All Blogs →</a>
</div>
