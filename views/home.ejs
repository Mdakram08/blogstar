<% layout("/layouts/boilerplate") %>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple-900: whitesmoke;;
      --purple-800: #000000;
      --purple-600: #000000;
      --purple-400: #000000;
      --purple-200: #000000;
      --purple-100: #000000;
      --purple-50: #000000;

      --teal-50: #E1F5EE;
      --teal-600: #0F6E56;
      --amber-50: #FAEEDA;
      --amber-600: #854F0B;
      --green-50: #EAF3DE;
      --green-600: #3B6D11;
      --coral-50: #FAECE7;
      --coral-600: #993C1D;

      --bg: #ffffff;
      --surface: #f8f8fc;
      --border: rgba(0,0,0,0.08);
      --text-primary: #0f0e1a;
      --text-secondary: #6b6a82;
      --text-muted: #a0a0b5;
      --radius-md: 8px;
      --radius-lg: 14px;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-y: hidden;
    }

    h1, h2, h3, .nav-logo, .section-title {
      font-family: 'Syne', sans-serif;
    }

    .hero {
      background: var(--purple-900);
      padding: 5rem 2.5rem;
      position: relative; overflow: hidden;
      height: 41rem;
     
    }
    .hero::before {
      content: 'B';
      position: absolute; right: 3rem; top: 50%; transform: translateY(-50%);
      font-family: 'Syne', sans-serif; font-size: 260px; font-weight: 600;
      color: rgba(255,255,255,0.04); pointer-events: none; line-height: 1;
    }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--purple-200); margin-bottom: 1.25rem;
    }
    .hero h1 {
      font-size: 52px; font-weight: 600; line-height: 1.15;
      max-width: 580px; color: #000000; margin-bottom: 1rem; letter-spacing: -1px;
      
    }
    .hero h1 em { color: var(--purple-200); font-style: normal; }
    .hero p { font-size: 16px; color: var(--purple-100); max-width: 500px; line-height: 1.75; margin-bottom: 2rem; }
    .hero-btns { display: flex; gap: 12px; }
    .hero-btn-primary { background: var(--purple-400); color: #fff; border: none; padding: 12px 24px; border-radius: var(--radius-md); font-size: 14px; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.2s; }
    .hero-btn-primary:hover { background: var(--purple-600); }
    .hero-btn-outline { background: transparent; color: var(--purple-100); border: 0.5px solid var(--purple-600); padding: 12px 24px; border-radius: var(--radius-md); font-size: 14px; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; }
    .hero-btn-outline:hover { background: rgba(255,255,255,0.05); }
    
  </style>
<body>
      

<!-- HERO -->
<section class="hero">
 <div class="row">

  <div class="col-8">
    <p class="hero-tag "><i class="ti ti-flame"></i> <b class=" fa-pen-fancy">BLOGSTAR</b></p>
    <h1>Stories that <em>inspire,</em> ideas that stick.</h1>
    <p>Dive into fresh perspectives across tech, travel, food, culture, and everything in between — all in one place.</p>
    <div class="hero-btns mt-10">
     <a href="/blog"><button class="hero-btn-primary">Explore articles</button></a>
     <a href="/signup"><button class="hero-btn-outline">Sign-Up </button></a>
    </div>
  </div>

  <div class="col-4">
     <h4 class=" heading"><b>STAY INFORMED,STAY UPDATED.</b></h4>
     <h3 class=""><b>Discover Articles That Matter</b></h3>
     <p>Explore insightful articles on technology, business, lifestyle, productivity, health, and the latest trends shaping the world. Our platform delivers high-quality content designed to inform, educate, and inspire readers every day.</p>
     <h3 class=""><b>Why Readers Choose Us?</b></h3>
     <ul>
      <li>Fresh articles published daily</li>
      <li>Trusted and researched content</li>
      <li>Easy-to-read modern design</li>
      <li>Expert insights and opinions</li>
      <li>Mobile-friendly reading experience</li>
     </ul>
  </div>
  
  
 
</section>


</body>
